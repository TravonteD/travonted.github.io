---
import Layout from "../layouts/Layout.astro";

const { frontmatter } = Astro.props;
---

<Layout title="Tray Dennis aka Work++">
  <main>
		<section class="max-w-3xl m-auto mb-20">
      <h1 class="text-center pt-10 text-3xl">{frontmatter.title}</h1>
      <h3 class="text-center text-lg pb-10">{frontmatter.date.toString().substring(0, 10)}</h1>
      <article class="prose lg:prose-xl">
        <slot/>
      </article>
		</section>
  </main>
</Layout>
